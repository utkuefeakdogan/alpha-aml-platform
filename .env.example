# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=datadb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_RAW=transactions.raw

# Generator — low-frequency mode (1 txn / 10–20 sec)
TXN_INTERVAL_MIN_SEC=10
TXN_INTERVAL_MAX_SEC=20
# Scenario scheduler (~50 alerts/day, random wake times)
SCENARIO_WAKE_MIN_SEC=1200
SCENARIO_WAKE_MAX_SEC=5400
SCENARIO_WAKE_JITTER_SEC=300
SCENARIO_DAILY_CAP=100
SCENARIO_RULE_COOLDOWN_SEC=10800
DAILY_ALERT_CAP=100
PER_RULE_DAILY_CAP=12
NORMAL_MAX_AMOUNT_EUR=8500
SCENARIO_CATALOG_PATH=/app/configs/scenario_catalog.json

# Spark
SPARK_MASTER=local[2]
SPARK_DRIVER_MEMORY=512m
SPARK_EXECUTOR_MEMORY=512m
CHECKPOINT_DIR=/tmp/spark-checkpoints

# Streamlit
STREAMLIT_PORT=8501
FREESQL_USER=freesql_reader
FREESQL_PASSWORD=freesql_readonly_2026
FREESQL_CONTACT_EMAIL=compliance@alpha-aml.local

# Airflow
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://user:password@postgres:5432/airflow_meta

# GenAI SAR (optional — mock used when unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SAR_MOCK_MODE=true

# Retention — single source of truth is configs/retention.json.
# These env vars are OPTIONAL overrides (leave unset to use the JSON file).
# Note: the legacy raw_transactions table was retired (migration 021), so there
# is no RAW_RETENTION_HOURS anymore.
TXN_RETENTION_DAYS=90
FLAGGED_RETENTION_DAYS=180
SAR_RETENTION_DAYS=180
METRICS_RETENTION_HOURS=4
METRICS_MAX_ROWS=50000

# Disk guard (Airflow disk_guard_dag + scripts/disk_guard.sh)
DISK_WARN_PCT=80
DISK_CRITICAL_PCT=90
PG_DB_WARN_BYTES=32212254720
METRICS_EMERGENCY_MAX_ROWS=200000

# Edge / HTTPS (docker compose --profile edge up -d caddy)
# SITE_ADDRESS is your public hostname; get a free one at https://www.duckdns.org
# (e.g. my-aml.duckdns.org). Caddy auto-issues a Let's Encrypt cert for it.
SITE_ADDRESS=
ACME_EMAIL=
# DuckDNS auto-updater (optional; Oracle IPs are usually static)
DUCKDNS_SUBDOMAINS=
DUCKDNS_TOKEN=

# Gold → BigQuery export bridge (Airflow DAG: export_to_bigquery)
# Requires a GCP project with billing + BigQuery API + Cloud Storage API.
# Place the service-account JSON at ./secrets/gcp-sa.json (gitignored).
GCP_PROJECT=alpha-aml
GCS_BUCKET=alpha-aml-staging
BQ_DATASET=aml_analytics
BQ_LOCATION=EU
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/secrets/gcp-sa.json
# Staging Parquet older than this many days is deleted after each successful sync
GCS_RETENTION_DAYS=7
