# Custom Airflow image for the Alpha AML pipeline.
#
# Why a dedicated image instead of `pip install` in the compose command?
#  - The previous setup ran an unconstrained `pip install dbt-postgres ... openai`
#    on every container start. pip's backtracking resolver explored dozens of
#    dbt versions against Airflow's pinned tree and hung for 25+ minutes on the
#    6 GB VM (competing with Spark for CPU), delaying scheduler boot.
#  - Baking deps into the image makes the scheduler boot instantly. Two tricks
#    keep the *build* itself fast and reproducible:
#      1. Airflow-side deps install against Airflow's official constraints file
#         (no version exploration).
#      2. dbt lives in its own isolated venv so its pins never fight Airflow's.
FROM apache/airflow:2.8.4-python3.11

ARG AIRFLOW_VERSION=2.8.4
ARG PYTHON_VERSION=3.11
ARG CONSTRAINTS="https://raw.githubusercontent.com/apache/airflow/constraints-${AIRFLOW_VERSION}/constraints-${PYTHON_VERSION}.txt"

# Postgres provider + GenAI client, pinned by the official constraints file.
RUN pip install --no-cache-dir \
        "apache-airflow-providers-postgres" \
        "psycopg2-binary" \
        "openai" \
        --constraint "${CONSTRAINTS}"

# dbt in an isolated virtualenv (invoked by the dbt_transform DAG via $DBT_BIN).
# Isolation means dbt's dependency pins can never break the Airflow runtime.
# /opt is root-owned, so build the venv as root, then restore the airflow user.
USER root
RUN python -m venv /opt/dbt-venv && \
    PIP_USER=false /opt/dbt-venv/bin/pip install --no-cache-dir "dbt-postgres==1.7.11"
USER airflow
